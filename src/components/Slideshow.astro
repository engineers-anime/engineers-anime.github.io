---
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'

/**
 * Slideshow Component
 *
 * @description A component that displays a slideshow of images from a specific directory
 */
interface Props {
  /**
   * The directory containing the images relative to src/assets/img/
   */
  folder: string
  /**
   * The aspect ratio of the slideshow container
   * @default '3/2'
   */
  aspectRatio?: string
  /**
   * The maximum width of the slideshow container
   * @default '100%'
   */
  maxWidth?: string
  /**
   * Whether to display a subtle border around the slideshow
   * @default false
   */
  hasBorder?: boolean
}

const { folder, aspectRatio = '3/2', maxWidth = '100%', hasBorder = false } = Astro.props

// Import images from the specified folder
const imageFiles = import.meta.glob<{ default: ImageMetadata }>('/src/assets/img/**/*.{png,jpg,jpeg,webp,JPG}')
const folderPath = `/src/assets/img/${folder}/`
const filteredKeys = Object.keys(imageFiles).filter((key) => key.startsWith(folderPath))

// Sort keys numerically
const sortedKeys = filteredKeys.sort((a, b) => {
  const numA = parseInt(a.match(/\d+/)?.[0] || '0')
  const numB = parseInt(b.match(/\d+/)?.[0] || '0')
  return numA - numB
})

const images = await Promise.all(sortedKeys.map((key) => imageFiles[key]()))
---

<div
  class={`slideshow-container relative w-full overflow-hidden rounded-lg ${hasBorder ? 'border border-neutral-400 dark:border-neutral-600' : ''}`}
  style={`aspect-ratio: ${aspectRatio}; max-width: ${maxWidth}; margin-inline: auto;`}
>
  {
    images.map((img, index) => (
      <Image
        class={`slideshow-image absolute inset-0 h-full w-full object-cover transition-opacity duration-1000 ${index === 0 ? 'opacity-100' : 'opacity-0'}`}
        src={img.default}
        alt=""
        decoding="async"
        loading={index === 0 ? 'eager' : 'lazy'}
      />
    ))
  }
</div>

<script>
  // Handle multiple slideshows on the same page
  const containers = document.querySelectorAll('.slideshow-container')

  containers.forEach((container) => {
    const images = container.querySelectorAll('.slideshow-image')
    if (images.length > 1) {
      let currentIndex = 0
      setInterval(() => {
        images[currentIndex].classList.replace('opacity-100', 'opacity-0')
        currentIndex = (currentIndex + 1) % images.length
        images[currentIndex].classList.replace('opacity-0', 'opacity-100')
      }, 5000)
    }
  })
</script>
