---
import { Card, Heading, Link } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
import Parser from 'rss-parser'
import { parse } from 'node-html-parser'

/**
 * FeaturedPosts Component
 *
 * @description A component that displays upcoming study groups from Connpass RSS
 */
interface Props {
  /**
   * Additional classes to apply to the section
   */
  class?: string
  /**
   * The maximum number of posts to display
   * @default 6
   */
  limit?: number
  /**
   * The title for the section
   * @default "近日開催の勉強会"
   */
  title?: string
}

interface Post {
  id: string
  title: string
  description: string
  eventDate: string
  eventLocation: string
  featuredImage: string | null
  url: string
  pubDate: string
  isUpcoming: boolean
}

const { class: className, limit = 6, title = '近日開催の勉強会' } = Astro.props

// Fetch study groups from Connpass RSS
const parser = new Parser()
let featuredPosts: Post[] = []

try {
  const feed = await parser.parseURL('https://engineers-anime.connpass.com/ja.atom')
  const now = new Date()

  const allPosts = await Promise.all(
    feed.items.map(async (item, index) => {
      let ogImage = ''
      if (item.link) {
        try {
          const res = await fetch(item.link)
          const html = await res.text()
          const root = parse(html)
          const ogImageMeta = root.querySelector('meta[property="og:image"]')
          if (ogImageMeta) {
            ogImage = ogImageMeta.getAttribute('content') || ''
          }
        } catch (e) {
          console.error('Error fetching OG image:', e)
        }
      }

      const summary = item.summary || ''
      const dateMatch = summary.match(/開催日時: (.*?)<br/)
      const locationMatch = summary.match(/開催場所: (.*?)<br/)
      
      const eventDateStr = dateMatch ? dateMatch[1] : ''
      const eventLocation = locationMatch ? locationMatch[1] : ''
      
      let isUpcoming = true
      if (eventDateStr) {
        const startDateStr = eventDateStr.split(' ～ ')[0]
        const eventStartDate = new Date(startDateStr.replace(/\//g, '-'))
        isUpcoming = eventStartDate >= now
      }

      let cleanDescription = summary
        .replace(/開催日時: .*?<br \/>/, '')
        .replace(/開催場所: .*?<br \/>/, '')
        .replace(/<[^>]*>?/gm, '')
        .trim()
        .substring(0, 100)

      return {
        id: item.id || String(index),
        title: item.title || '',
        description: cleanDescription,
        eventDate: eventDateStr,
        eventLocation,
        featuredImage: ogImage || null,
        url: item.link || '',
        pubDate: item.pubDate || item.isoDate || '',
        isUpcoming
      }
    })
  )

  featuredPosts = allPosts
    .filter(post => post.isUpcoming)
    .slice(0, limit)

} catch (error) {
  console.error('Error fetching Connpass RSS:', error)
}
---

<section id="upcoming-events" class:list={[className, 'my-64']}>
  <div class="container">
    <Heading level="h2" class="mb-6">{title}</Heading>
    <div class="grid grid-cols-1 gap-12 md:grid-cols-2 lg:grid-cols-3">
      {
        featuredPosts.length > 0 ? (
          featuredPosts.map((post) => (
            <Card
              img={post.featuredImage || 'https://placehold.co/640x360?text=No+Image'}
              url={post.url}
              headingLevel="h2"
              title={post.title}
            >
              <div class="flex flex-col gap-2 text-sm mb-4">
                {post.eventDate && (
                  <div class="flex items-start gap-2">
                    <Icon name="lucide:calendar-days" size="1.2rem" class="mt-0.5 text-primary-500" />
                    <span><strong>日時:</strong> {post.eventDate}</span>
                  </div>
                )}
                {post.eventLocation && (
                  <div class="flex items-start gap-2">
                    <Icon name="lucide:map-pin" size="1.2rem" class="mt-0.5 text-primary-500" />
                    <span><strong>場所:</strong> {post.eventLocation}</span>
                  </div>
                )}
              </div>
              <p class="line-clamp-3">{post.description}...</p>
            </Card>
          ))
        ) : (
          <p class="text-xl">現在、近日開催予定の勉強会はありません。公式Xでの告知をお待ちください！</p>
        )
      }
    </div>
    <div class="mt-12">
      <Link href="https://engineers-anime.connpass.com/" isButton isExternal animateOnHover animationType="nudge">
        過去の勉強会を見る（Connpass）
        <Icon aria-hidden="true" name="lucide:arrow-right" size="1.5rem" />
      </Link>
    </div>
  </div>
</section>
