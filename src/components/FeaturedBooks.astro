---
import { Card, Heading, Link } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
import { parse } from 'node-html-parser'
import { books } from '../data/booth-books'

/**
 * FeaturedBooks Component
 *
 * @description A component that displays published books from BOOTH
 */
interface Props {
  /**
   * Additional classes to apply to the section
   */
  class?: string
  /**
   * The title for the section
   * @default "発行した同人誌"
   */
  title?: string
}

const { class: className, title = '制作した技術同人誌' } = Astro.props

const bookDetails = await Promise.all(
  books.map(async (url) => {
    let details = {
      title: 'エンジニアニメ技術同人誌',
      description: 'アニメと技術を掛け合わせた知見をまとめた一冊です。',
      image: 'https://placehold.co/640x360?text=BOOTH+Book',
      url: url,
    }

    try {
      const res = await fetch(url, {
        headers: { 'User-Agent': 'Mozilla/5.0' },
      })
      const html = await res.text()
      const root = parse(html)

      const ogTitle = root.querySelector('meta[property="og:title"]')?.getAttribute('content')
      const ogDesc = root.querySelector('meta[property="og:description"]')?.getAttribute('content')
      const ogImage = root.querySelector('meta[property="og:image"]')?.getAttribute('content')

      if (ogTitle) details.title = ogTitle.replace(' - BOOTH', '')
      if (ogDesc) details.description = ogDesc
      if (ogImage) details.image = ogImage
    } catch (e) {
      console.error('Error fetching BOOTH OG info:', e)
    }

    return details
  }),
)
---

<section id="published-books" class:list={[className, 'my-64']}>
  <div class="container">
    <Heading level="h2" class="mb-6">{title}</Heading>
    <div class="grid grid-cols-1 gap-12 md:grid-cols-2 lg:grid-cols-3">
      {
        bookDetails.map((book) => (
          <Card img={book.image} url={book.url} headingLevel="h2" title={book.title}>
            <p class="line-clamp-4">{book.description}</p>
          </Card>
        ))
      }
    </div>
    <div class="mt-12">
      <Link href="https://engineers-anime.booth.pm/" isButton isExternal animateOnHover animationType="nudge">
        BOOTHで本を確認する
        <Icon aria-hidden="true" name="lucide:shopping-cart" size="1.5rem" />
      </Link>
    </div>
  </div>
</section>
