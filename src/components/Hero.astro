---
import { Link } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'

/**
 * Hero Component
 *
 * @description A component that displays a hero section with a title, description, and image
 */
interface Props {
  /**
   * The source URL for the image
   */
  src?: string
}

const { src = '/astronaut-hero-img.webp' }: Props = Astro.props

// Import images from src/assets/img/top_slide
const imageFiles = import.meta.glob<{ default: ImageMetadata }>('/src/assets/img/top_slide/*.{png,jpg,jpeg,webp}')
// Sort keys to ensure they are in order (1.png, 2.png, ...)
const sortedKeys = Object.keys(imageFiles).sort((a, b) => {
  const numA = parseInt(a.match(/\d+/)?.[0] || '0')
  const numB = parseInt(b.match(/\d+/)?.[0] || '0')
  return numA - numB
})
const images = await Promise.all(sortedKeys.map((key) => imageFiles[key]()))
---

<section class="hero mt-12 mb-24">
  <div class="container">
    <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2 lg:gap-24">
      <div class="flex flex-col items-center gap-8 md:items-start">
        <h1
          class="overflow-visible py-4 text-center text-4xl leading-normal whitespace-nowrap md:text-left md:text-6xl lg:text-7xl"
        >
          <slot><span class="text-gradient">エンジニアニメ</span></slot>
        </h1>
        <div class="image-container relative block w-full overflow-hidden rounded-xl lg:hidden">
          {
            images.length > 0 ? (
              images.map((img, index) => (
                <Image
                  class={`hero-image absolute inset-0 h-full w-full object-cover transition-opacity duration-1000 ${index === 0 ? 'opacity-100' : 'opacity-0'}`}
                  src={img.default}
                  alt=""
                  decoding="async"
                  width={600}
                  height={600}
                  loading="eager"
                />
              ))
            ) : (
              <Image
                class="h-full w-full object-cover"
                src={src}
                alt=""
                decoding="async"
                width={600}
                height={600}
                loading="eager"
              />
            )
          }
        </div>
        <div class="flex flex-col gap-3 min-[500px]:flex-row">
          <Link
            href="https://twitter.com/intent/follow?screen_name=engineers_anime"
            isButton
            type="primary"
            animateOnHover
            animationType="boop"
          >
            <Icon aria-hidden="true" name="simple-icons:x" size="1.5rem" />
            公式Xをフォロー
          </Link>
          <Link href="#upcoming-events" isButton type="secondary" animateOnHover animationType="boop">
            <Icon aria-hidden="true" name="lucide:calendar" size="1.5rem" />
            勉強会を確認する
          </Link>
        </div>
      </div>
      <div class="image-container relative hidden w-full overflow-hidden rounded-xl lg:block">
        {
          images.length > 0 ? (
            images.map((img, index) => (
              <Image
                class={`hero-image absolute inset-0 h-full w-full object-cover transition-opacity duration-1000 ${index === 0 ? 'opacity-100' : 'opacity-0'}`}
                src={img.default}
                alt=""
                decoding="async"
                width={600}
                height={600}
                loading="eager"
              />
            ))
          ) : (
            <Image
              class="h-full w-full object-cover"
              src={src}
              alt=""
              decoding="async"
              width={600}
              height={600}
              loading="eager"
            />
          )
        }
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  h1 {
    text-wrap: unset;
  }

  .text-gradient {
    background: linear-gradient(315deg, #ff8c00 25%, #ffd700);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    display: inline-block;
    padding-top: 0.1em;
  }

  .image-container {
    aspect-ratio: 1 / 1;
    max-width: 600px;
    margin-inline: auto;
  }
</style>

<script>
  const images = document.querySelectorAll('.hero-image')
  if (images.length > 1) {
    let currentIndex = 0
    setInterval(() => {
      images[currentIndex].classList.replace('opacity-100', 'opacity-0')
      currentIndex = (currentIndex + 1) % images.length
      images[currentIndex].classList.replace('opacity-0', 'opacity-100')
    }, 5000)
  }
</script>
