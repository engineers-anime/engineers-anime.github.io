---
import CallToAction from './CallToAction.astro'
import Logo from './Logo.astro'
import { Heading, Link } from 'accessible-astro-components'

/**
 * Footer Component
 *
 * @description A component that displays the footer of the website
 */
const currentYear = new Date().getFullYear()
---

<footer>
  <CallToAction />
  <section class="py-20">
    <Heading level="h2" class="sr-only">Footer</Heading>
    <div class="container grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
      <div class="flex flex-col gap-4">
        <Logo loading="lazy" isLink={false} />
        <p class="leading-[1.75]">
          エンジニアニメは、アニメと技術を愛するすべてのエンジニアのためのコミュニティです。<br />
          主催者: <Link isExternal href="https://x.com/uutan1108">うーたん</Link>
        </p>
      </div>
      <div class="flex flex-col gap-4">
        <Heading level="h3" size="h6">コミュニティ</Heading>
        <ul class="flex flex-col gap-2">
          <li>
            <Link isExternal href="https://discord.gg/dgPWe6rNWS">Discord</Link>
          </li>
          <li>
            <Link isExternal href="https://twitter.com/engineers_anime">公式X (Twitter)</Link>
          </li>
          <li>
            <Link isExternal href="https://github.com/engineers-anime">GitHub</Link>
          </li>
          <li>
            <Link isExternal href="https://engineers-anime.connpass.com/">Connpass</Link>
          </li>
        </ul>
      </div>
      <div class="flex flex-col gap-4">
        <Heading level="h3" size="h6">イラスト</Heading>
        <ul class="flex flex-col gap-2">
          <li>
            <Link isExternal href="https://x.com/DDDD__akagi">赤城ナツイチ</Link>
          </li>
        </ul>
        <Heading level="h3" size="h6">ロゴ</Heading>
        <ul class="flex flex-col gap-2">
          <li>
            <Link isExternal href="https://x.com/mottox2">もっと</Link>
          </li>
        </ul>
      </div>
    </div>
  </section>
  <section class="py-8">
    <div class="container flex flex-col gap-4 md:flex-row md:justify-between">
      <p>
        &copy; {currentYear} - エンジニアニメ.
      </p>
    </div>
  </section>
</footer>

<style>
  section {
    border-top: 1px solid var(--border-color-subtle);
  }
</style>
