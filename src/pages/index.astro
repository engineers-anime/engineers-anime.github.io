---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import Hero from '@components/Hero.astro'
import Feature from '@components/Feature.astro'
import Counter from '@components/Counter.astro'
import ContentMedia from '@components/ContentMedia.astro'
import FeaturedPosts from '@components/FeaturedPosts.astro'
import FeaturedBooks from '@components/FeaturedBooks.astro'
import { Accordion, AccordionItem, Heading, Link } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
import { parse } from 'node-html-parser'
import { books } from '@utils/books'
import firstImage from '../assets/img/picture/event.JPG'
import secondImage from '../assets/img/picture/books.png'

// Calculate activity months since 2024/05/07
const startDate = new Date('2024-05-07')
const today = new Date()
const monthsDiff = (today.getFullYear() - startDate.getFullYear()) * 12 + (today.getMonth() - startDate.getMonth())
const activityMonths = `${monthsDiff}+`

// Scrape Connpass data at build time
let memberCount = '600+' // Default value if scraping fails
let eventCount = '30+' // Default value if scraping fails
try {
  const response = await fetch('https://engineers-anime.connpass.com/', {
    headers: { 'User-Agent': 'Mozilla/5.0' },
  })
  const html = await response.text()
  const root = parse(html)

  // Extract member count more robustly
  const sideArea = root.querySelector('#side_area')
  if (sideArea) {
    const memberAmount = sideArea.querySelector('.amount')
    if (memberAmount) {
      memberCount = memberAmount.text.trim()
    }
  }

  // Extract event count
  const eventLink = root.querySelectorAll('a').find((a) => a.text.includes('全てのイベントを見る'))
  if (eventLink) {
    const match = eventLink.text.match(/（(\d+)件）/)
    if (match) {
      eventCount = match[1]
    }
  }
} catch (error) {
  console.error('Error scraping Connpass:', error)
}

const bookCount = books.length.toString()
---

<DefaultLayout useTitleTemplate={false}>
  <Hero />
  <section class="my-64">
    <div class="container">
      <Heading level="h2" class="mb-8">活動内容</Heading>
      <div class="grid grid-cols-1 gap-12 md:grid-cols-3">
        <Feature icon="lucide:users" title="コミュニティー運営">
          「アニメから得た学びをエンジニア同士で語り合う」をコンセプトに、エンジニアのモチベーション維持やキャリア形成に繋がる交流の場を運営しています。
        </Feature>
        <Feature icon="lucide:calendar" title="勉強会の実施">
          勉強会「アニメから得た学びを発表会」をはじめ、アニメの聖地や都内で平日夜に勉強会など、多様な場所や規模で開催しています。
        </Feature>
        <Feature icon="lucide:book-open" title="同人誌の作成">
          技術書典などのイベントと連動し、アニメと技術を掛け合わせた知見やコミュニティの活動をまとめた技術同人誌の制作・頒布を行っています。
        </Feature>
      </div>
    </div>
  </section>
  <ContentMedia imgSrc={firstImage.src}>
    <Heading level="h2">勉強会を開催</Heading>
    <p class="text-2xl">
      「アニメから得た学びを発表会」をはじめとした、勉強会を展開しています。エンジニア独自の視点でアニメを深掘りし、新しい気づきを共有する場を提供しています。
    </p>
  </ContentMedia>
  <ContentMedia imgSrc={secondImage.src} reverseImg={true}>
    <Heading level="h2">同人誌の制作</Heading>
    <p class="text-2xl">
      技術書典などのイベントにて、アニメとエンジニアリングを掛け合わせた技術同人誌を制作・頒布しています。コミュニティの集合知を一冊の本として形にしています。
    </p>
  </ContentMedia>
  <FeaturedPosts />
  <FeaturedBooks />
  <section class="my-64">
    <div class="container grid grid-cols-1 gap-12 md:grid-cols-2">
      <div class="flex flex-col items-start gap-4">
        <Heading level="h2">よくある質問</Heading>
        <p class="text-2xl">コミュニティへの参加や活動に関するよくある質問をまとめています。</p>
        <div class="flex flex-wrap gap-4">
          <Link
            href="https://twitter.com/intent/follow?screen_name=engineers_anime"
            isButton
            isExternal
            type="primary"
            animateOnHover
            animationType="boop"
          >
            <Icon aria-hidden="true" name="simple-icons:x" size=" 1.5rem" />
            公式Xをフォロー
          </Link>
          <div class="discord-button-wrapper">
            <Link
              href="https://discord.gg/dgPWe6rNWS"
              isButton
              isExternal
              type="secondary"
              animateOnHover
              animationType="boop"
            >
              <Icon aria-hidden="true" name="simple-icons:discord" size=" 1.5rem" />
              Discordに参加
            </Link>
          </div>
        </div>
      </div>
      <div class="space-content">
        <Accordion>
          <AccordionItem name="exclusive" title="初心者でも参加できますか？" open>
            <p>もちろんです！アニメが好き、またはエンジニアリングに興味がある方なら、経験を問わず大歓迎です。</p>
          </AccordionItem>
          <AccordionItem name="exclusive" title="主な活動場所はどこですか？">
            <p>定期的に都内でのオフライン交流会を開催しています。山手線沿線のアクセスしやすい場所が多いです。</p>
          </AccordionItem>
          <AccordionItem name="exclusive" title="どのような技術スタックの人が多いですか？">
            <p>Webエンジニア、モバイルエンジニア、AIエンジニア、デザイナーなど、多種多様な方々が参加しています。</p>
          </AccordionItem>
          <AccordionItem name="exclusive" title="参加費用はかかりますか？">
            <p>
              コミュニティへの基本的な参加は無料です。特定のイベントや懇親会などの際には実費をいただく場合があります。
            </p>
          </AccordionItem>
        </Accordion>
      </div>
    </div>
  </section>
  <section class="mt-64 mb-32">
    <div class="container">
      <Heading level="h2" class="mb-16">数字で見るエンジニアニメ</Heading>
      <div class="grid grid-cols-1 gap-12 sm:grid-cols-2 md:grid-cols-4">
        <Counter count={memberCount} title="Members" sub="コミュニティ人数" />
        <Counter count={eventCount} title="Events" sub="累計イベント開催数" />
        <Counter count={bookCount} title="Books" sub="発行した同人誌の冊数" />
        <Counter count={activityMonths} title="Months" sub="活動期間" />
      </div>
    </div>
  </section>
</DefaultLayout>

<style>
  .discord-button-wrapper {
    :global(.button.secondary) {
      border-color: #5865f2 !important;
      background-color: #5865f2 !important;
      color: white !important;

      &:hover,
      &:focus-visible {
        border-color: color-mix(in srgb, #5865f2, black 10%) !important;
        background-color: color-mix(in srgb, #5865f2, black 10%) !important;
      }
    }
  }
</style>
